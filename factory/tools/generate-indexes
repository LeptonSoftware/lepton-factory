#!/usr/bin/env python3
"""Regenerate the factory's discoverability indexes.

Writes .factory/indexes/{requirements,blueprints,work-orders}.generated.md and
docs/testing/test-catalog.generated.md by scraping authoritative sources
(front matter, headings, state.yaml, COV-/REQ-/AC- test tags). Output is
deterministic (stable sort) so diffs are meaningful; CI fails when indexes
are stale. Generated files are never hand-edited. Scratch WOs (numbered >=
.factory/config.yaml ids.scratch_min) are excluded from the WO index.
"""

import argparse
import os
import re
import sys

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
import _lib  # noqa: E402

HEADER = "<!-- This file is generated by tools/agent/generate-indexes. Do not edit. -->\n"


# Directories never scanned: package/build/venv output would otherwise leak
# copied or generated files (with real tag text) into the catalog and make
# --check outcomes depend on whether anything has been built.
PRUNE_DIRS = {"node_modules", "target", "build", "dist", "out", "__pycache__",
              "venv", ".venv", "htmlcov", "coverage", "vendor"}


def _prune(dirs):
    dirs[:] = sorted(d for d in dirs
                     if not d.startswith(".") and d not in PRUNE_DIRS)


def walk_md(base):
    for root, dirs, files in os.walk(base):
        _prune(dirs)
        for name in sorted(files):
            if name.endswith(".md"):
                yield os.path.join(root, name)


def scrape_requirements(cfg):
    """One row per REQ definition found under the requirements tree."""
    base = os.path.join(_lib.repo_root(),
                        cfg.get("paths", {}).get("requirements", "docs/product/features"))
    req_re = re.compile(r"^###\s+(REQ-[A-Z0-9]+-[0-9]{3}):\s*(.+)$")
    rows = []
    if os.path.isdir(base):
        for path in walk_md(base):
            fm, body = _lib.parse_front_matter(_lib.read_text(path))
            status = fm.get("status", "")
            for line in body.splitlines():
                m = req_re.match(line.strip())
                if m:
                    rows.append((m.group(1), m.group(2).strip(), str(status), _lib.rel(path)))
    return sorted(rows)


def scrape_blueprints(cfg):
    base = os.path.join(_lib.repo_root(),
                        cfg.get("paths", {}).get("blueprints", "docs/architecture"))
    bp_re = re.compile(r"\b(BP-(?:CONT|COMP|FEAT)-[A-Z0-9-]+)\b")
    rows = []
    if os.path.isdir(base):
        for path in walk_md(base):
            name = os.path.basename(path)
            if name in ("TEMPLATE.md", "README.md"):
                continue
            fm, body = _lib.parse_front_matter(_lib.read_text(path))
            m = bp_re.search(name) or bp_re.search(body)
            if not m:
                continue
            title = fm.get("title", "")
            if not title:
                h = re.search(r"^#\s+(.+)$", body, re.M)
                title = h.group(1).strip() if h else name
            rows.append((m.group(1), str(title), str(fm.get("status", "")), _lib.rel(path)))
    return sorted(set(rows))


def scrape_work_orders(cfg):
    rows = []
    for wo_id, path in _lib.list_wo_dirs(cfg):
        title = ""
        wo_md = os.path.join(path, "work-order.md")
        if os.path.isfile(wo_md):
            h = re.search(r"^#\s+%s:\s*(.+)$" % re.escape(wo_id),
                          _lib.read_text(wo_md), re.M)
            title = h.group(1).strip() if h else ""
        status = tier = phase = ""
        sp = os.path.join(path, "state.yaml")
        if os.path.isfile(sp):
            try:
                st = _lib.parse_yaml(_lib.read_text(sp))
                status = str(st.get("status", ""))
                tier = str(st.get("risk_tier", ""))
                phase = str(st.get("current_phase", ""))
            except ValueError:
                status = "UNPARSEABLE state.yaml"
        rows.append((wo_id, title, status, tier, phase, _lib.rel(path)))
    return rows  # list_wo_dirs is already sorted


# Polyglot monorepo: TypeScript, Python, Rust, Java, shell.
# Candidate test files, by suffix…
TEST_EXTS = (".test.ts", ".test.tsx", ".spec.ts", ".spec.tsx", ".test.js",
             ".spec.js", ".test.jsx", ".test.mjs",
             ".test.py", "_test.py", "Test.java", "Tests.java",
             "IT.java", ".bats", ".test.sh")
# …by directory (covers src/test/java via "src/test", Criterion via "benches")…
TEST_DIR_HINTS = ("tests", "test", "__tests__", "e2e", "src/test", "it",
                  "benches")
# …by prefix (pytest's dominant convention), and by content probe for Rust
# (inline #[test]/#[cfg(test)] modules live inside src/*.rs source files).
RUST_TEST_MARKERS = ("#[test]", "#[cfg(test)]")

# The tag contract (docs/testing/writing-tests.md): the literal ID string —
# optionally preceded by '@' — appears anywhere in the test file's text:
# a title/tag string, @Tag("COV-…"), @pytest.mark.cov("COV-…"), or an
# adjacent comment like `# COV: COV-…` / `// COV: COV-…`.
TAG_RE = re.compile(r"\b((?:COV|REQ|AC)-[A-Z0-9]+-[0-9]{3}(?:\.[0-9]+)?)\b")


def looks_like_test(name, relp):
    if name.endswith(TEST_EXTS):
        return True
    if name.startswith("test_") and name.endswith(".py"):
        return True
    return any("/%s/" % h in "/" + relp + "/" for h in TEST_DIR_HINTS)


def scrape_test_catalog():
    """Scan likely test files (suffix, prefix, test dirs, Rust content probe)
    for COV-/REQ-/AC- IDs."""
    root = _lib.repo_root()
    rows = []
    for base, dirs, files in os.walk(root):
        _prune(dirs)
        for name in files:
            path = os.path.join(base, name)
            relp = _lib.rel(path)
            candidate = looks_like_test(name, relp)
            rust_probe = not candidate and name.endswith(".rs")
            if not candidate and not rust_probe:
                continue
            try:
                text = _lib.read_text(path)
            except (UnicodeDecodeError, OSError):
                continue
            if rust_probe and not any(m in text for m in RUST_TEST_MARKERS):
                continue
            tags = sorted(set(TAG_RE.findall(text)))
            if tags:
                rows.append((relp, tags))
    return sorted(rows)


def table(headers, rows):
    out = ["| " + " | ".join(headers) + " |",
           "|" + "|".join("---" for _ in headers) + "|"]
    for r in rows:
        out.append("| " + " | ".join(str(c) for c in r) + " |")
    if not rows:
        out.append("| _none yet_ " + "| " * (len(headers) - 1) + "|")
    return "\n".join(out) + "\n"


def write_if_changed(path, content, check):
    current = _lib.read_text(path) if os.path.isfile(path) else None
    if current == content:
        return False
    if check:
        return True
    os.makedirs(os.path.dirname(path), exist_ok=True)
    # Atomic write (temp file + os.replace): a crash or concurrent reader never
    # sees a truncated index.
    tmp = path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        f.write(content)
        f.flush()
        os.fsync(f.fileno())
    os.replace(tmp, path)
    return True


def main():
    ap = argparse.ArgumentParser(
        prog="generate-indexes",
        description="Regenerate .factory/indexes/*.generated.md and "
                    "docs/testing/test-catalog.generated.md from authoritative sources.")
    ap.add_argument("--check", action="store_true",
                    help="exit 1 if any index is stale, without writing (CI mode)")
    args = ap.parse_args()

    cfg = _lib.load_config()
    root = _lib.repo_root()
    idx = os.path.join(root, cfg.get("paths", {}).get("indexes", ".factory/indexes"))

    outputs = {
        os.path.join(idx, "requirements.generated.md"):
            HEADER + "# Requirements Index\n\n" +
            table(("REQ", "Title", "Status", "Path"), scrape_requirements(cfg)),
        os.path.join(idx, "blueprints.generated.md"):
            HEADER + "# Blueprints Index\n\n" +
            table(("Blueprint", "Title", "Status", "Path"), scrape_blueprints(cfg)),
        os.path.join(idx, "work-orders.generated.md"):
            HEADER + "# Work Orders Index\n\n" +
            table(("WO", "Outcome", "Status", "Tier", "Phase", "Path"),
                  scrape_work_orders(cfg)),
        os.path.join(root, "docs", "testing", "test-catalog.generated.md"):
            HEADER + "# Test Catalog\n\n"
            "Source of truth is the test files' `COV-`/`REQ-`/`AC-` IDs "
            "(optionally `@`-prefixed, in framework metadata or adjacent "
            "comments — see docs/testing/writing-tests.md); this catalog is "
            "scraped from them.\n\n" +
            table(("Test file", "Covers"),
                  [(p, ", ".join(tags)) for p, tags in scrape_test_catalog()]),
    }

    stale = []
    for path, content in outputs.items():
        if write_if_changed(path, content, args.check):
            stale.append(_lib.rel(path))

    if args.check and stale:
        _lib.die("stale generated indexes: %s — run tools/agent/generate-indexes "
                 "and commit the result." % ", ".join(stale))
    print("indexes up to date" if not stale
          else "regenerated: %s" % ", ".join(stale))


if __name__ == "__main__":
    main()
